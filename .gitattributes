# Normalize line endings to LF in the repo (prevents CRLF churn + protects shell scripts).
* text=auto eol=lf

# Scripts MUST be LF or they break in Alpine/Docker (#!/bin/sh\r → "not found").
*.sh text eol=lf
docker-entrypoint.sh text eol=lf

# Binaries
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.db binary
*.woff binary
*.woff2 binary
