generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Node {
  id          String   @id @default(cuid())
  label       String
  type        String   // project | idea | task | goal | note | person | workflow | decision | problem | roadmap | system
  status      String   @default("inbox") // inbox | active | blocked | done | archived
  description String?
  content     String?
  priority    String?  @default("medium") // low | medium | high | urgent
  color       String?
  icon        String?
  posX        Float    @default(0)
  posY        Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  sourceEdges Edge[]          @relation("SourceNode")
  targetEdges Edge[]          @relation("TargetNode")
  tasks       Task[]
  goals       Goal[]
  notes       Note[]
  checklists  ChecklistItem[]
  conversations AIConversation[]

  @@map("nodes")
}

model Edge {
  id         String   @id @default(cuid())
  sourceId   String
  targetId   String
  label      String?
  type       String   @default("default") // default | dependency | reference | related
  animated   Boolean  @default(true)
  createdAt  DateTime @default(now())

  source Node @relation("SourceNode", fields: [sourceId], references: [id], onDelete: Cascade)
  target Node @relation("TargetNode", fields: [targetId], references: [id], onDelete: Cascade)

  @@map("edges")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("todo") // todo | in_progress | blocked | done | cancelled
  priority    String    @default("medium") // low | medium | high | urgent
  dueDate     DateTime?
  completedAt DateTime?
  nodeId      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  node      Node?          @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  checklist ChecklistItem[]

  @@map("tasks")
}

model Goal {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("active") // active | achieved | abandoned | paused
  progress    Int       @default(0) // 0-100
  targetDate  DateTime?
  nodeId      String?
  projectId   String?
  goalType    String    @default("personal") // business | personal
  target      Float?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  node       Node?           @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  milestones GoalMilestone[]

  @@map("goals")
}

model GoalMilestone {
  id          String    @id @default(cuid())
  goalId      String
  title       String
  completed   Boolean   @default(false)
  completedAt DateTime?
  targetDate  DateTime?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@map("goal_milestones")
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String
  tags      String?  // JSON array of strings
  nodeId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  node Node? @relation(fields: [nodeId], references: [id], onDelete: SetNull)

  @@map("notes")
}

model ChecklistItem {
  id          String    @id @default(cuid())
  text        String
  completed   Boolean   @default(false)
  completedAt DateTime?
  order       Int       @default(0)
  nodeId      String?
  taskId      String?
  createdAt   DateTime  @default(now())

  node Node? @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@map("checklist_items")
}

model AIConversation {
  id        String      @id @default(cuid())
  title     String?
  nodeId    String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  node     Node?       @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  messages AIMessage[]

  @@map("ai_conversations")
}

model AIMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // user | assistant
  content        String
  createdAt      DateTime @default(now())

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("ai_messages")
}

model Capture {
  id             String   @id @default(cuid())
  title          String
  content        String
  source         String   @default("manual")  // chatgpt | claude | manual | whatsapp | email | meeting | other
  type           String   @default("note")     // note | task | idea | decision | bug | roadmap | goal | project_update | sales_note | technical_note | lead | demo_note | support_issue | onboarding_note | product_feedback
  status         String   @default("inbox")   // inbox | processed | archived
  priority       String   @default("medium")  // low | medium | high | urgent
  tags           String?                       // JSON array
  nodeId         String?
  convertedToType String?
  convertedToId   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("captures")
}

// ============================================================
// BUSINESS OS MODELS
// ============================================================

model Product {
  id                     String   @id @default(cuid())
  name                   String
  shortDescription       String
  targetCustomers        String
  painPoints             String
  coreFeatures           String   // JSON array of strings
  demoAngle              String
  pricingRange           String
  implementationComplexity String  @default("medium") // low | medium | high
  status                 String   @default("building") // idea | building | demo-ready | pilot-ready | live
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  leads        Lead[]
  deployments  Deployment[]
  upsells      UpsellOpportunity[]
  supportIssues SupportIssue[]

  @@map("products")
}

model Lead {
  id                String    @id @default(cuid())
  companyName       String
  contactName       String?
  email             String?
  phone             String?
  website           String?
  linkedin          String?
  industry          String?
  companySize       String?
  painPoint         String?
  recommendedProductId String?
  leadSource        String?   @default("manual") // manual | referral | linkedin | website | event | cold_outreach | partner
  status            String    @default("new") // new | researched | contacted | replied | discovery_scheduled | demo_scheduled | demo_done | proposal_sent | pilot_offered | pilot_active | won | lost | archived
  priority          String    @default("medium") // low | medium | high | urgent
  estimatedValue    Float?
  notes             String?
  nextAction        String?
  nextActionDate    DateTime?
  // Demo prep
  demoAngle         String?
  discoveryQuestions String?
  likelyObjections  String?
  pilotStructure    String?
  pricingSuggestion String?
  demoNextSteps     String?
  // Proposal
  proposalStatus    String?   @default("not_started") // not_started | draft | sent | negotiating | accepted | rejected
  proposalAmount    Float?
  monthlyPrice      Float?
  setupFee          Float?
  // Pilot
  pilotStatus       String?   @default("not_started") // not_started | offered | active | completed | converted | failed
  pilotStartDate    DateTime?
  pilotEndDate      DateTime?
  pilotSuccessCriteria String?
  pilotNotes        String?
  decisionDeadline  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  recommendedProduct Product? @relation(fields: [recommendedProductId], references: [id], onDelete: SetNull)
  onboardingItems    OnboardingItem[]
  deployments        Deployment[]
  upsells            UpsellOpportunity[]
  supportIssues      SupportIssue[]

  @@map("leads")
}

model OnboardingItem {
  id          String    @id @default(cuid())
  leadId      String
  text        String
  completed   Boolean   @default(false)
  completedAt DateTime?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("onboarding_items")
}

model Deployment {
  id            String    @id @default(cuid())
  leadId        String?
  productId     String?
  status        String    @default("planned") // planned | configuring | testing | live | paused | cancelled
  environment   String    @default("demo")    // demo | pilot | production
  monthlyPrice  Float?
  setupStatus   String?
  lastCheckIn   DateTime?
  nextCheckIn   DateTime?
  issuesCount   Int       @default(0)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  lead    Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("deployments")
}

model SupportIssue {
  id          String   @id @default(cuid())
  leadId      String?
  productId   String?
  deploymentId String?
  title       String
  description String?
  severity    String   @default("medium") // low | medium | high | critical
  status      String   @default("open")  // open | in_progress | waiting_customer | resolved | archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lead    Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("support_issues")
}

model UpsellOpportunity {
  id               String    @id @default(cuid())
  leadId           String?
  currentProductId String?
  suggestedProductId String?
  reason           String?
  status           String    @default("identified") // identified | discussed | proposed | accepted | rejected | archived
  estimatedValue   Float?
  nextActionDate   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  lead             Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  currentProduct   Product? @relation(fields: [currentProductId], references: [id], onDelete: SetNull)

  @@map("upsell_opportunities")
}

// ============================================================
// AGENT OS MODELS
// ============================================================

model Agent {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  description        String?
  status             String   @default("active")  // active | paused | disabled
  agentType          String   @default("custom")  // strategy | research | lead_generation | outreach | project_management | custom
  prompt             String?
  systemPrompt       String?
  scheduleEnabled    Boolean  @default(false)
  scheduleExpression String?
  requiresApproval   Boolean  @default(true)
  role               String?
  mission            String?
  successMetric      String?
  authorityLevel     String?  @default("research") // coordinate | delegate | research | review | observe
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  runs            AgentRun[]
  schedule        AgentSchedule?
  memories        AgentMemory[]
  agentTools      AgentTool[]
  sourceWorkflows AgentWorkflow[] @relation("WorkflowSource")
  targetWorkflows AgentWorkflow[] @relation("WorkflowTarget")
  promptVersions  AgentPromptVersion[]
  goals           AgentGoal[]
  scorecards      AgentScorecard[]

  @@map("agents")
}

model AgentRun {
  id           String    @id @default(cuid())
  agentId      String
  status       String    @default("pending") // pending | running | completed | failed | cancelled
  inputContext String?   // JSON blob
  output       String?   // JSON blob
  error        String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  agent     Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  approvals ApprovalQueue[]

  @@map("agent_runs")
}

model AgentSchedule {
  id        String    @id @default(cuid())
  agentId   String    @unique
  enabled   Boolean   @default(false)
  frequency String    @default("manual") // daily | weekly | monthly | manual
  timeOfDay String?   // HH:MM
  lastRunAt DateTime?
  nextRunAt DateTime?

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_schedules")
}

model ApprovalQueue {
  id             String    @id @default(cuid())
  agentRunId     String
  actionType     String
  proposedAction String    // JSON blob
  reason         String?
  status         String    @default("pending") // pending | approved | rejected
  approvedBy     String?
  approvedAt     DateTime?
  createdAt      DateTime  @default(now())

  agentRun AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@map("approval_queue")
}

// ============================================================
// AGENT OS — PHASE 1.5: INTELLIGENCE FOUNDATION
// ============================================================

model AgentMemory {
  id              String   @id @default(cuid())
  agentId         String
  memoryType      String   @default("fact") // fact | decision | preference | pattern | lesson | risk | opportunity
  title           String
  content         String
  importance      Int      @default(5)      // 1–10
  occurrenceCount Int      @default(1)
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_memories")
}

model Tool {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  description      String?
  enabled          Boolean  @default(true)
  requiresApproval Boolean  @default(true)
  inputSchema      String?  // JSON schema for tool inputs
  outputSchema     String?  // JSON schema for tool outputs
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  agentTools     AgentTool[]
  toolExecutions ToolExecution[]

  @@map("tools")
}

model AgentTool {
  id      String @id @default(cuid())
  agentId String
  toolId  String

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tool  Tool  @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([agentId, toolId])
  @@map("agent_tools")
}

model AgentWorkflow {
  id            String   @id @default(cuid())
  name          String
  sourceAgentId String
  targetAgentId String
  triggerType   String   @default("manual") // manual | approved_action | completed_run
  enabled       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sourceAgent Agent @relation("WorkflowSource", fields: [sourceAgentId], references: [id], onDelete: Cascade)
  targetAgent Agent @relation("WorkflowTarget", fields: [targetAgentId], references: [id], onDelete: Cascade)

  @@map("agent_workflows")
}

model AgentPromptVersion {
  id                 String   @id @default(cuid())
  agentId            String
  version            Int
  systemPrompt       String?
  userPromptTemplate String?
  createdAt          DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, version])
  @@map("agent_prompt_versions")
}

// ============================================================
// PHASE 2.1 — COMMERCE AUTOPILOT
// ============================================================

model CommerceOpportunity {
  id                    String   @id @default(cuid())
  title                 String
  opportunityType       String   @default("digital_product") // ai_product | digital_product | affiliate | reseller | plr | dropshipping | productized_service | ads_campaign | lead_generation
  targetCustomer        String?
  painPoint             String?
  offer                 String?
  estimatedRevenue      Float?
  estimatedMargin       Float?
  buildEffort           String   @default("medium") // low | medium | high
  salesDifficulty       String   @default("medium") // low | medium | high
  fulfillmentDifficulty String   @default("medium") // low | medium | high
  riskLevel             String   @default("medium") // low | medium | high
  status                String   @default("discovered") // discovered | validating | approved | rejected | testing | live | archived
  source                String?
  notes                 String?
  createdByAgentId      String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("commerce_opportunities")
}

model Prospect {
  id                  String   @id @default(cuid())
  companyName         String
  contactName         String?
  role                String?
  email               String?
  phone               String?
  linkedinUrl         String?
  website             String?
  industry            String?
  country             String?
  companySize         String?
  fitScore            Int?
  painPointHypothesis String?
  suggestedOffer      String?
  source              String?
  status              String   @default("discovered") // discovered | qualified | rejected | converted_to_lead | archived
  createdByAgentId    String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("prospects")
}

model CampaignDraft {
  id                String   @id @default(cuid())
  name              String
  channel           String   @default("email") // linkedin | email | google_ads | meta_ads | instagram | facebook | retargeting | landing_page
  goal              String?
  targetAudience    String?
  offer             String?
  hook              String?
  adCopy            String?
  outreachMessage   String?
  landingPageAngle  String?
  cta               String?
  suggestedBudget   Float?
  expectedObjection String?
  successMetric     String?
  status            String   @default("draft") // draft | pending_approval | approved | rejected | ready_to_launch | launched_manually | archived
  createdByAgentId  String?
  sourceApprovalId  String?
  sourceOutputId    String?
  projectId         String?
  opportunityId     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("campaign_drafts")
}

model FulfillmentFlow {
  id                        String   @id @default(cuid())
  name                      String
  productName               String
  paymentProvider           String   @default("manual") // stripe | gumroad | shopify | manual
  deliveryType              String   @default("email_delivery") // email_delivery | download_link | license_key | affiliate_redirect | manual_delivery | onboarding_call
  confirmationEmailTemplate String?
  invoiceRequired           Boolean  @default(false)
  deliveryEmailTemplate     String?
  followUpEmailTemplate     String?
  supportInstructions       String?
  status                    String   @default("draft") // draft | approved | active | archived
  createdByAgentId          String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@map("fulfillment_flows")
}

model ConnectorRegistry {
  id               String   @id @default(cuid())
  name             String
  provider         String   @unique // linkedin | gmail | outlook | stripe | meta_ads | google_ads | shopify | gumroad | web_search | browser
  status           String   @default("planned") // planned | configured | disabled
  requiresApproval Boolean  @default(true)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("connector_registry")
}

// ============================================================
// PHASE 1.9 — EXECUTION LAYER
// ============================================================

model ExecutionHistory {
  id            String    @id @default(cuid())
  approvalId    String
  agentId       String
  actionType    String
  actionPayload String    // JSON blob of the parsed proposed action
  status        String    @default("pending") // pending | executed | failed
  error         String?
  executedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@map("execution_history")
}

model WorkflowExecution {
  id            String    @id @default(cuid())
  workflowId    String
  sourceAgentId String
  targetAgentId String
  triggerType   String    // completed_run | approved_action | manual
  status        String    @default("pending") // pending | executed | failed | blocked
  reason        String?
  createdAt     DateTime  @default(now())
  executedAt    DateTime?

  @@map("workflow_executions")
}

model ScheduleExecution {
  id          String    @id @default(cuid())
  scheduleId  String
  agentId     String
  status      String    @default("success") // success | failed | skipped
  reason      String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@map("schedule_executions")
}

model ToolExecution {
  id          String    @id @default(cuid())
  toolId      String
  agentId     String
  input       String?   // JSON blob
  output      String?   // JSON blob
  status      String    @default("pending") // pending | success | failed
  error       String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@map("tool_executions")
}

model MemorySuggestion {
  id               String   @id @default(cuid())
  agentId          String
  runId            String
  memoryType       String   @default("fact") // fact | decision | preference | pattern | lesson | risk | opportunity
  classification   String   @default("fact") // fact | decision | preference | pattern | lesson | risk | opportunity | observation
  title            String
  content          String
  importance       Int      @default(5)
  importanceReason String?
  status           String   @default("pending") // pending | approved | rejected
  createdAt        DateTime @default(now())

  @@map("memory_suggestions")
}

model SystemExecutionLog {
  id         String   @id @default(cuid())
  sourceType String   // agent | workflow | schedule | tool | approval
  sourceId   String
  event      String
  details    String?  // JSON blob
  createdAt  DateTime @default(now())

  @@map("system_execution_logs")
}

// ============================================================
// PHASE 2.0 — INTELLIGENCE QUALITY LAYER
// ============================================================

model Insight {
  id         String   @id @default(cuid())
  type       String   @default("risk")   // risk | opportunity | efficiency | revenue | execution
  title      String
  summary    String
  confidence Int      @default(5)        // 1–10
  importance Int      @default(5)        // 1–10
  agentId    String?
  runId      String?
  status     String   @default("active") // active | dismissed
  createdAt  DateTime @default(now())

  @@map("insights")
}

model PatternRecord {
  id          String   @id @default(cuid())
  patternType String   @default("blocker") // blocker | overdue | approval_delay | revenue_risk | operational_risk
  title       String
  description String
  occurrences Int      @default(1)
  agentId     String?
  runId       String?
  status      String   @default("pending") // pending | approved | rejected | dismissed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("pattern_records")
}

model ExecutiveBriefing {
  id            String   @id @default(cuid())
  summary       String
  risks         String   // JSON array of strings
  opportunities String   // JSON array of strings
  actions       String   // JSON array of strings
  patterns      String?  // JSON array of strings
  insights      String?  // JSON array of strings
  agentId       String?
  runId         String?
  createdAt     DateTime @default(now())

  @@map("executive_briefings")
}

// ============================================================
// PHASE 2.1A — MULTI-AGENT COMMUNICATION FOUNDATION
// ============================================================

model AgentMessage {
  id          String    @id @default(cuid())
  fromAgentId String
  toAgentId   String
  subject     String
  content     String
  context     String?   // JSON blob
  priority    String    @default("medium") // low | medium | high | critical
  status      String    @default("unread") // unread | read | archived
  createdAt   DateTime  @default(now())
  readAt      DateTime?

  @@map("agent_messages")
}

model AgentDelegation {
  id                String    @id @default(cuid())
  assignedByAgentId String
  assignedToAgentId String
  objective         String
  inputContext      String?   // JSON blob
  expectedOutput    String?
  status            String    @default("pending") // pending | accepted | running | completed | failed | cancelled
  result            String?
  error             String?
  createdAt         DateTime  @default(now())
  startedAt         DateTime?
  completedAt       DateTime?

  @@map("agent_delegations")
}

model AgentWorkspace {
  id            String   @id @default(cuid())
  name          String
  description   String?
  workspaceType String   @default("strategy") // strategy | revenue | opportunity | research | operations | project | custom
  status        String   @default("active")   // active | paused | completed | archived
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members    AgentWorkspaceMember[]
  activities WorkspaceActivity[]

  @@map("agent_workspaces")
}

model AgentWorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  agentId     String
  role        String   @default("observer") // executive | researcher | validator | planner | reviewer | observer
  createdAt   DateTime @default(now())

  workspace AgentWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, agentId])
  @@map("agent_workspace_members")
}

model WorkspaceActivity {
  id           String   @id @default(cuid())
  workspaceId  String
  activityType String   @default("message") // message | delegation | memory | execution | approval
  sourceId     String?
  summary      String
  createdAt    DateTime @default(now())

  workspace AgentWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_activities")
}

// ============================================================
// PHASE 2.2 — PRODUCTION AUTONOMY READINESS
// ============================================================

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}

// ============================================================
// PHASE 2.3 — EXECUTIVE LOOP, AGENT GOALS & SCORECARDS
// ============================================================

model AgentGoal {
  id            String    @id @default(cuid())
  agentId       String
  title         String
  description   String?
  goalType      String    @default("custom")   // revenue | opportunity | execution | research | operations | knowledge | support | custom
  targetMetric  String?
  targetValue   Float?
  currentValue  Float     @default(0)
  period        String    @default("weekly")   // daily | weekly | monthly | quarterly | ongoing
  status        String    @default("active")   // active | paused | completed | failed | archived
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  completedAt   DateTime?

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_goals")
}

model ExecutiveLoopRun {
  id                 String    @id @default(cuid())
  triggerType        String    @default("manual")    // manual | scheduled | goal_review | briefing | system
  status             String    @default("running")   // running | completed | failed
  summary            String?
  decisions          String?   // JSON array of decision strings
  createdDelegations Int       @default(0)
  createdMessages    Int       @default(0)
  createdWorkspaces  Int       @default(0)
  error              String?
  startedAt          DateTime  @default(now())
  completedAt        DateTime?

  @@map("executive_loop_runs")
}

model AgentReviewRequest {
  id                 String    @id @default(cuid())
  requestedByAgentId String
  reviewerAgentId    String
  workspaceId        String?
  delegationId       String?
  subject            String
  content            String
  context            String?   // JSON blob
  status             String    @default("pending")   // pending | in_review | approved | rejected | needs_changes
  reviewResult       String?
  reviewNotes        String?
  createdAt          DateTime  @default(now())
  completedAt        DateTime?

  @@map("agent_review_requests")
}

model AgentScorecard {
  id                   String   @id @default(cuid())
  agentId              String
  periodStart          DateTime
  periodEnd            DateTime
  runsCompleted        Int      @default(0)
  runsFailed           Int      @default(0)
  delegationsAssigned  Int      @default(0)
  delegationsCompleted Int      @default(0)
  delegationsFailed    Int      @default(0)
  messagesSent         Int      @default(0)
  reviewsCompleted     Int      @default(0)
  approvalsCreated     Int      @default(0)
  approvalsApproved    Int      @default(0)
  approvalsRejected    Int      @default(0)
  memoriesCreated      Int      @default(0)
  insightsGenerated    Int      @default(0)
  usefulnessScore      Float    @default(5)
  reliabilityScore     Float    @default(5)
  executionScore       Float    @default(5)
  qualityScore         Float    @default(5)
  overallScore         Float    @default(5)
  summary              String?
  createdAt            DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_scorecards")
}

// ============================================================
// PHASE 2.4A — INTELLIGENCE CONNECTORS & EXTERNAL AWARENESS
// ============================================================

model SearchResearch {
  id                 String    @id @default(cuid())
  query              String
  requestedByAgentId String?
  workspaceId        String?
  status             String    @default("pending")  // pending | completed | failed
  summary            String?
  sources            String?   // JSON array of {url, title, snippet}
  resultsCount       Int       @default(0)
  createdAt          DateTime  @default(now())
  completedAt        DateTime?

  @@map("search_research")
}

model EmailInsight {
  id             String   @id @default(cuid())
  agentId        String?
  emailCount     Int      @default(0)
  unreadCount    Int      @default(0)
  importantCount Int      @default(0)
  summary        String?
  createdAt      DateTime @default(now())

  @@map("email_insights")
}

model CalendarInsight {
  id             String   @id @default(cuid())
  agentId        String?
  todayEvents    Int      @default(0)
  upcomingEvents Int      @default(0)
  nextDeadline   String?
  summary        String?
  createdAt      DateTime @default(now())

  @@map("calendar_insights")
}

model ResearchRequest {
  id                 String    @id @default(cuid())
  requestedByAgentId String?
  workspaceId        String?
  title              String
  objective          String
  priority           String    @default("medium")  // low | medium | high | critical
  status             String    @default("pending")  // pending | running | completed | failed
  resultSummary      String?
  createdAt          DateTime  @default(now())
  completedAt        DateTime?

  results ResearchResult[]

  @@map("research_requests")
}

model ResearchResult {
  id              String   @id @default(cuid())
  requestId       String
  summary         String
  findings        String   // JSON array of finding strings
  risks           String?  // JSON array of risk strings
  opportunities   String?  // JSON array of opportunity strings
  recommendations String?  // JSON array of recommendation strings
  confidenceScore Int      @default(5) // 1-10
  createdAt       DateTime @default(now())

  request ResearchRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("research_results")
}

// ============================================================
// PHASE 2 — WORKFORCE BACKBONE
// ============================================================

model WorkforceTeam {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  departmentType String   // executive | research | commerce | sales | marketing | content | operations | support | development
  objective      String?
  status         String   @default("active") // active | paused | inactive
  currentFocus   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  outputs        WorkforceOutput[]
  handoffsFrom   TeamHandoff[]     @relation("HandoffFrom")
  handoffsTo     TeamHandoff[]     @relation("HandoffTo")
  approvals      Approval[]
  assignments    Assignment[]
  // Phase 8 — Runtime
  runtimeQueue   RuntimeQueue[]
  objectives     TeamObjective[]
  autonomyConfig AutonomyConfig?

  @@map("workforce_teams")
}

model WorkforceOutput {
  id             String    @id @default(cuid())
  teamId         String
  ownerTeamId    String?
  title          String
  description    String?
  content        String?   // full markdown content
  outputType     String    @default("research") // research | product_candidate | prospect | campaign | content | automation | tool | mvp | support_insight | process_improvement | revenue_opportunity | approval_request | briefing_note
  status         String    @default("draft")    // draft | in_review | approved | handed_off | in_progress | completed | archived
  projectId      String?
  goalId         String?
  revenueEntryId String?
  opportunityId  String?   // Phase 8 — linked Opportunity
  reviewedAt     DateTime?
  approvedAt     DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  team     WorkforceTeam    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  feedback OutputFeedback[]

  @@map("workforce_outputs")
}

model OutputFeedback {
  id             String   @id @default(cuid())
  outputId       String
  assignmentId   String?
  teamId         String?
  departmentType String?
  decision       String   // approved | rejected | revised | acknowledged
  comment        String?
  helpful        Boolean  @default(true)
  createdAt      DateTime @default(now())

  output WorkforceOutput @relation(fields: [outputId], references: [id], onDelete: Cascade)

  @@map("output_feedback")
}

model WorkflowTemplate {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  steps       String   // JSON: Array<{ department: string; title: string; dependsOn?: string[] }>
  category    String   @default("general") // general | validation | launch | research | sales
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("workflow_templates")
}

model TeamHandoff {
  id              String    @id @default(cuid())
  fromTeamId      String
  toTeamId        String
  title           String
  description     String?
  status          String    @default("pending") // pending | accepted | in_progress | completed | rejected
  relatedOutputId String?
  projectId       String?
  priority        String    @default("medium")  // low | medium | high | urgent
  notes           String?
  acceptedAt      DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  fromTeam WorkforceTeam @relation("HandoffFrom", fields: [fromTeamId], references: [id], onDelete: Cascade)
  toTeam   WorkforceTeam @relation("HandoffTo", fields: [toTeamId], references: [id], onDelete: Cascade)

  @@map("team_handoffs")
}

model Approval {
  id              String    @id @default(cuid())
  title           String
  description     String?
  reason          String?
  status          String    @default("pending") // pending | approved | rejected | auto_approved
  sourceTeamId    String?
  relatedOutputId String?
  projectId       String?
  priority        String    @default("medium")  // low | medium | high | urgent
  decisionType    String    @default("founder_decision") // approve_outreach | approve_campaign | approve_content | approve_product | approve_deployment | approve_budget | approve_proposal | review_research | founder_decision
  riskLevel       String    @default("medium")  // low | medium | high | critical
  approvedAt      DateTime?
  autoApprovedAt  DateTime? // set when auto-approved by triage
  escalatedAt     DateTime? // set when escalation alert was sent
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sourceTeam WorkforceTeam? @relation(fields: [sourceTeamId], references: [id], onDelete: SetNull)

  @@map("approvals")
}

model AlertLog {
  id        String   @id @default(cuid())
  alertType String   // runtime_offline | queue_stuck | assignment_failure | critical_approval | project_blocked | api_failure | connector_failure
  severity  String   // info | warning | error | critical
  message   String
  channel   String   // discord | ntfy | none
  dedupKey  String   // used for cooldown — alertType + date or context hash
  metadata  String   @default("{}") // JSON
  sentAt    DateTime @default(now())

  @@map("alert_logs")
}

model RevenueEntry {
  id                String    @id @default(cuid())
  title             String
  amount            Float
  currency          String    @default("EUR")
  revenueType       String    @default("pipeline") // pipeline | potential | live | closed
  serviceType       String    @default("service")  // service | product
  status            String    @default("active")   // active | closed_won | closed_lost
  projectId         String?
  sourceTeamId      String?
  opportunityId     String?   // Phase 9 — linked Opportunity
  probability       Float?
  expectedCloseDate DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("revenue_entries")
}

model Project {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  status        String   @default("active")  // active | paused | blocked | completed | archived
  priority      String   @default("medium")  // low | medium | high | urgent
  nextAction    String?
  blocker       String?
  revenueImpact Float?
  opportunityId String?   // Phase 9 — linked Opportunity (auto-created projects)
  autoCreated   Boolean   @default(false) // Phase 9 — created by Opportunity Engine
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("projects")
}

model Assignment {
  id             String    @id @default(cuid())
  title          String
  description    String?
  status         String    @default("pending") // pending | active | review | completed | archived
  teamId         String
  projectId      String?
  goalId         String?
  revenueEntryId String?
  opportunityId  String?   // Phase 8 — linked Opportunity
  priority       String    @default("medium")  // low | medium | high | urgent
  createdAt      DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  updatedAt      DateTime  @updatedAt

  team     WorkforceTeam      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  messages AssignmentMessage[]

  @@map("assignments")
}

model AssignmentMessage {
  id           String   @id @default(cuid())
  assignmentId String
  senderType   String   @default("operator") // operator | team | system
  content      String
  createdAt    DateTime @default(now())

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@map("assignment_messages")
}

// ============================================================
// PHASE 4 — WORKFORCE EXECUTION ENGINE
// ============================================================

model AutomationRule {
  id           String   @id @default(cuid())
  name         String
  trigger      String   // assignment_completed | output_approved | handoff_completed
  condition    String?  // JSON: { departmentType?, outputType?, priority? }
  action       String   // create_handoff | create_approval | create_assignment
  actionConfig String   // JSON: { toTeamType?, title?, priority?, decisionType? }
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("automation_rules")
}

// ============================================================
// PHASE 8 — RUNTIME ENGINE
// ============================================================

model RuntimeQueue {
  id           String    @id @default(cuid())
  teamId       String
  assignmentId String?
  title        String
  description  String?
  priority     String    @default("medium") // low | medium | high | urgent
  status       String    @default("queued") // queued | running | completed | failed
  source       String    @default("runtime") // runtime | founder | handoff | objective | schedule | executive
  attempts     Int       @default(0)
  maxAttempts  Int       @default(3)
  error        String?
  lockedAt     DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  team WorkforceTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("runtime_queue")
}

model TeamObjective {
  id          String    @id @default(cuid())
  teamId      String
  title       String
  description String
  frequency   String    @default("daily") // hourly | daily | weekly
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  team WorkforceTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("team_objectives")
}

model AutonomyConfig {
  id               String   @id @default(cuid())
  teamId           String   @unique
  canSelfInitiate  Boolean  @default(false)
  requiresApproval Boolean  @default(true)
  approvalTriggers String   @default("[]") // JSON: ["outreach","campaign","content","deployment","budget"]
  maxDailyRuns     Int      @default(3)
  operateSilently  Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  team WorkforceTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("autonomy_configs")
}

model IntelligenceSignal {
  id          String    @id @default(cuid())
  signalType  String    // email | calendar | web | manual | internal
  source      String    // provider name or "internal"
  title       String
  content     String
  metadata    String    @default("{}") // JSON blob
  processed   Boolean   @default(false)
  processedAt DateTime?
  teamId      String?
  agentId     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("intelligence_signals")
}

model RuntimeState {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("runtime_state")
}

// ============================================================
// PHASE 9 — ARTIFACT ENGINE
// ============================================================

model Artifact {
  id            String    @id @default(cuid())
  title         String
  content       String    // Rich markdown content — the executable business artifact
  artifactType  String    // prospect_list | market_analysis | validation_report | outreach_sequence | campaign | ad_angles | landing_page | product_page | proposal | demo_spec | automation_blueprint | technical_plan | deployment_plan | faq | knowledge_base | executive_review
  status        String    @default("draft")  // draft | ready | approved | superseded | archived
  sourceTeamId  String?
  assignmentId  String?
  outputId      String?   // linked WorkforceOutput
  opportunityId String?   // linked Opportunity
  projectId     String?
  goalId        String?
  metadata      String?   // JSON blob for extra structured fields
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("artifacts")
}

// ============================================================
// PHASE 8 — OPPORTUNITY ENGINE
// ============================================================

model Opportunity {
  id                       String    @id @default(cuid())
  title                    String
  description              String?
  opportunityType          String    // automation_service | ecommerce_product | saas_product | content_business | internal_tool
  source                   String    @default("research") // research | goal | project | manual | market_signal | condition_check
  status                   String    @default("discovered") // discovered | researching | validating | approved | building | marketing | selling | demo | pilot | deployment | live | revenue_generating | rejected | archived
  currentStage             String?   // current workflow stage label
  score                    Int       @default(5)  // 1-10 business potential
  confidence               Int       @default(5)  // 1-10 confidence in opportunity
  estimatedRevenue         Float?
  estimatedEffort          String?   // low | medium | high
  market                   String?
  targetCustomer           String?
  evidence                 String?   // JSON array of evidence strings
  risks                    String?   // JSON array of risk strings
  assumptions              String?   // JSON array of assumption strings
  validationPlan           String?
  executionStrategy        String?
  nextRecommendedStep      String?
  assignedWorkflowTemplate String?   // automation_service | ecommerce | saas | content | internal
  workflowChain            String?   // JSON: ordered dept array ["sales","development","marketing"]
  currentStageIndex        Int       @default(0)
  projectId                String?
  goalId                   String?
  revenueEntryId           String?
  sourceOutputId           String?   // WorkforceOutput that triggered this
  workflowRoutedAt         DateTime? // set when workflow chain was created
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@map("opportunities")
}

// ============================================================
// PHASE 9 — APPROVAL ACTION DISPATCHER
// ============================================================

model ActionResult {
  id           String   @id @default(cuid())
  approvalId   String   @unique
  actionType   String   // approve_outreach | approve_campaign | approve_content | approve_product | approve_deployment | approve_proposal | review_research | founder_decision
  status       String   @default("dispatched") // dispatched | failed
  title        String
  description  String?
  targetType   String?  // email_draft | campaign_draft | content_draft | product_draft | proposal_draft | development_draft | workforce_output
  targetId     String?
  error        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("action_results")
}

model EmailDraft {
  id               String   @id @default(cuid())
  title            String
  subject          String?
  body             String?
  recipientName    String?
  recipientEmail   String?
  status           String   @default("draft") // draft | ready | archived
  sourceApprovalId String?
  sourceOutputId   String?
  projectId        String?
  opportunityId    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("email_drafts")
}

model ContentDraft {
  id               String   @id @default(cuid())
  title            String
  body             String?
  platform         String?  // wordpress | webflow | ghost | linkedin | x | instagram
  tags             String?  // JSON array
  publishingNotes  String?
  status           String   @default("draft") // draft | ready | archived
  sourceApprovalId String?
  sourceOutputId   String?
  projectId        String?
  opportunityId    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("content_drafts")
}

model ProductDraft {
  id               String   @id @default(cuid())
  title            String
  description      String?
  priceSuggestion  Float?
  supplierNotes    String?
  marginNotes      String?
  imagesNeeded     String?
  launchChecklist  String?  // JSON array
  status           String   @default("draft") // draft | ready | archived
  sourceApprovalId String?
  sourceOutputId   String?
  projectId        String?
  opportunityId    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("product_drafts")
}

model ProposalDraft {
  id               String   @id @default(cuid())
  title            String
  customer         String?
  problem          String?
  solution         String?
  pricing          String?
  scope            String?
  timeline         String?
  status           String   @default("draft") // draft | ready | sent | archived
  sourceApprovalId String?
  sourceOutputId   String?
  projectId        String?
  opportunityId    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("proposal_drafts")
}

model DevelopmentDraft {
  id                      String   @id @default(cuid())
  title                   String
  repoNameSuggestion      String?
  readmeContent           String?
  fileStructure           String?  // markdown outline
  implementationChecklist String?  // JSON array
  status                  String   @default("draft") // draft | ready | archived
  sourceApprovalId        String?
  sourceOutputId          String?
  projectId               String?
  opportunityId           String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("development_drafts")
}
