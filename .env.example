# ════════════════════════════════════════════════════════════════
# MioOS — Environment Configuration Template
# Copy this file to .env.local (development) or .env (production)
# and fill in your values. Never commit the filled-in file.
# ════════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────────
# Development (local SQLite):
DATABASE_URL="file:./prisma/mioos.db"
# Production (Docker volume):
# DATABASE_URL="file:/data/mioos.db"
# Production (PostgreSQL — change Prisma provider to postgresql first):
# DATABASE_URL="postgresql://mioos:password@localhost:5432/mioos"

# ── Authentication ────────────────────────────────────────────────
# The only credentials that grant access to MioOS.
MIOOS_USERNAME="your-username"
MIOOS_PASSWORD="your-strong-password"

# Session signing secret — REQUIRED in production.
# Generate with: openssl rand -hex 32
SESSION_SECRET=""

# ── App URLs ──────────────────────────────────────────────────────
# Development:
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production:
# APP_URL="https://mio.aion-platform.eu"
# NEXT_PUBLIC_APP_URL="https://mio.aion-platform.eu"

# ── Scheduler ────────────────────────────────────────────────────
# Set to true to enable the internal schedule runner in development.
# In production (NODE_ENV=production) it starts automatically.
ENABLE_SCHEDULE_RUNNER=false

# ── AI Integration (optional) ─────────────────────────────────────
# Enables live Anthropic AI in the AI Assistant panel and agent runs.
# ANTHROPIC_API_KEY="sk-ant-..."
NEXT_PUBLIC_AI_ENABLED=false

# ── Docker context ────────────────────────────────────────────────
# Set by docker-compose automatically — do not change manually.
# DOCKER_ENV=true

# ── Future connectors (do NOT enable yet — approval gates required) ─
# WEB_SEARCH_API_KEY=""
# EMAIL_PROVIDER_API_KEY=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# STRIPE_SECRET_KEY=""
# GUMROAD_API_KEY=""
