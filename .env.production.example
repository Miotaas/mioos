# ════════════════════════════════════════════════════════════════
# MioOS — Production Environment Template
# Copy to .env on your VPS and fill in real values.
# NEVER commit this file with real secrets.
# ════════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────────
# Docker volume (SQLite — default single-instance deployment)
DATABASE_URL="file:/data/mioos.db"

# PostgreSQL alternative (change Prisma provider to postgresql first):
# DATABASE_URL="postgresql://mioos:STRONG_PASSWORD@localhost:5432/mioos"

# ── Authentication ────────────────────────────────────────────────
# The only credentials that grant access to MioOS.
# Use a strong unique password — this is your entire access control.
MIOOS_USERNAME="your-username"
MIOOS_PASSWORD="your-strong-unique-password"

# REQUIRED in production — generate with: openssl rand -hex 32
SESSION_SECRET="replace-with-64-char-hex-string"

# ── App URLs ──────────────────────────────────────────────────────
APP_URL="https://mio.aion-platform.eu"
NEXT_PUBLIC_APP_URL="https://mio.aion-platform.eu"

# ── Scheduler ────────────────────────────────────────────────────
# Legacy scheduler for old Agent system.
# MioOS Runtime is started separately with:
# npm run runtime
ENABLE_SCHEDULE_RUNNER=true

# ── AI Integration ────────────────────────────────────────────────
# Uncomment and set to enable live Anthropic AI in agents
AI_PROVIDER=claude
ANTHROPIC_API_KEY="your-anthropic-api-key"
NEXT_PUBLIC_AI_ENABLED=true

# ── Docker context ────────────────────────────────────────────────
DOCKER_ENV=true
NODE_ENV=production

# ── Future connectors (do NOT enable yet — approval gates required) ─
# WEB_SEARCH_API_KEY=""
# EMAIL_PROVIDER_API_KEY=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# STRIPE_SECRET_KEY=""
# GUMROAD_API_KEY=""

# Email
EMAIL_IMAP_HOST=""
EMAIL_IMAP_USER=""
EMAIL_IMAP_PASSWORD=""

# Search
SERPER_API_KEY=""
TAVILY_API_KEY=""

# Runtime Worker — start separately with PM2 or Docker Compose.
# See DEPLOYMENT.md for instructions.
# RUNTIME_ENABLED is informational — the worker is started as a separate process.

# ── Phase A — Outbound email (SMTP) ───────────────────────────────────
# Required for the Action Execution Layer to actually send approved outreach.
# Gmail example: host=smtp.gmail.com port=587 user=you@gmail.com pass=<app password>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Optional: max emails sent per runtime tick (default 10)
OUTBOUND_EMAIL_BATCH=10
