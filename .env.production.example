# ════════════════════════════════════════════════════════════════
# MioOS — Production Environment Template
# Copy to .env on your VPS and fill in real values.
# NEVER commit this file with real secrets.
# ════════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────────
# Docker volume (SQLite — default single-instance deployment)
DATABASE_URL="file:/data/mioos.db"

# PostgreSQL alternative (change Prisma provider to postgresql first):
# DATABASE_URL="postgresql://mioos:STRONG_PASSWORD@localhost:5432/mioos"

# ── Authentication ────────────────────────────────────────────────
# The only credentials that grant access to MioOS.
# Use a strong unique password — this is your entire access control.
MIOOS_USERNAME="your-username"
MIOOS_PASSWORD="your-strong-unique-password"

# REQUIRED in production — generate with: openssl rand -hex 32
SESSION_SECRET="replace-with-64-char-hex-string"

# ── App URLs ──────────────────────────────────────────────────────
APP_URL="https://mio.aion-platform.eu"
NEXT_PUBLIC_APP_URL="https://mio.aion-platform.eu"

# ── Scheduler ────────────────────────────────────────────────────
# Must be true in production for autonomous agent scheduling
ENABLE_SCHEDULE_RUNNER=true

# ── AI Integration ────────────────────────────────────────────────
# Uncomment and set to enable live Anthropic AI in agents
# ANTHROPIC_API_KEY="sk-ant-..."
NEXT_PUBLIC_AI_ENABLED=false

# ── Docker context ────────────────────────────────────────────────
DOCKER_ENV=true
NODE_ENV=production

# ── Future connectors (do NOT enable yet — approval gates required) ─
# WEB_SEARCH_API_KEY=""
# EMAIL_PROVIDER_API_KEY=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# STRIPE_SECRET_KEY=""
# GUMROAD_API_KEY=""
